# Copy to .env.local for local development.
# For production (Netlify): Site settings → Environment variables → set each key.
# Never commit real secrets.

# Cloudflare Turnstile (secret from Turnstile widget settings)
TURNSTILE_SECRET_KEY=

# Resend (https://resend.com) — verified domain sender required for RESEND_FROM_EMAIL
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=you@example.com

# Random secret used to hash rate-limit identifiers (openssl rand -hex 32)
RATE_LIMIT_SALT=
